{
    "manifest_version": 3,
    "name": "Backup Teams Token Sync",
    "version": "1.0.0",
    "description": "Securely synchronize your Microsoft Teams token for backup operations.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Backup Teams Token Sync"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "*://teams.microsoft.com/*",
        "https://api.backup-teams.com/*"
    ]
}